{
  "name": "notes-vault",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Приватное офлайн-first приложение заметок с шифрованием на покое (PWA).",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "npm run build && wrangler dev",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "postbuild": "node scripts/spa-404.mjs",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "dompurify": "^3.2.3",
    "idb": "^8.0.0",
    "libsodium-wrappers-sumo": "0.7.16",
    "marked": "^15.0.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router": "^7.1.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.43.0",
    "@eslint/js": "^9.17.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/libsodium-wrappers-sumo": "^0.7.8",
    "@types/node": "^22.10.2",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "fake-indexeddb": "^6.0.0",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.2",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.0.5",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^2.1.8",
    "wrangler": "^4.107.0"
  }
}
